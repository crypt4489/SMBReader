	<GLSLShader type="vert">
		UIVertexShader.vert
	</GLSLShader>
	<GLSLShader type="fragment">
		UIPixelShader.frag
	</GLSLShader>
	<ShaderResourceSet>
		<ShaderResourceItem type="storage" used="v" rw="read">
		</ShaderResourceItem>
		<ShaderResourceItem type="bufferView" used="v" rw="read">
		</ShaderResourceItem>
		<ShaderResourceItem type="storage" used="v" rw="read">
		</ShaderResourceItem>
	</ShaderResourceSet>
</ShaderGraph>

